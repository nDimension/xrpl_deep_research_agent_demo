# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# .env is gitignored — never commit real keys or seeds.

# ---------------------------------------------------------------------------
# LLM backend — set whichever you plan to use (--llm claude or --llm openai)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.5

# ---------------------------------------------------------------------------
# XRPL wallets (TESTNET ONLY — fund both at https://xrpl.org/xrp-testnet-faucet.html)
# ---------------------------------------------------------------------------
XRPL_SEED=sEd-provider-payee-seed-here     # provider's wallet (receives payments)
BUYER_SEED=sEd-agent-buyer-seed-here       # agent's wallet (pays the paywalls)
BUYER_ADDRESS=r-buyer-address-here         # optional cross-check of BUYER_SEED

# ---------------------------------------------------------------------------
# Optional — defaults shown; override only if needed
# ---------------------------------------------------------------------------
# XRPL_PAY_TO=                                          # provider receive address (derived from XRPL_SEED if unset)
# XRPL_FACILITATOR_URL=https://xrpl-facilitator-testnet.t54.ai
# XRPL_SOURCE_TAG=20260601
# XRPL_TESTNET_RPC_URL=https://s.altnet.rippletest.net:51234/
